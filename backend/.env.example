# Copy this file to .env and fill in your values

ELEVENLABS_API_KEY=your-elevenlabs-api-key
DEEPL_API_KEY=your-deepl-api-key

# LiteLLM proxy (all Gemini calls route through this)
GEMINI_API_KEY=sk-your-litellm-proxy-key       # bearer token for the proxy
LITELLM_API_BASE=https://litellm.deriv.ai/v1   # proxy base URL (change if self-hosting)
GEMINI_MODEL=gemini-2.0-flash                   # model name as configured in the proxy

# Allowed frontend origins (comma-separated for multiple)
FRONTEND_URL=http://localhost:3000

# Server settings
HOST=0.0.0.0
PORT=8000
